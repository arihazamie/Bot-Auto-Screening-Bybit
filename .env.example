# ═══════════════════════════════════════════════════════════════════
#  .env.example — Template secrets untuk Bot Auto Screening Bybit
# ═══════════════════════════════════════════════════════════════════
#
#  CARA PAKAI:
#    1.  cp .env.example .env
#    2.  Edit .env dan isi nilai yang sesuai
#    3.  JANGAN commit file .env ke Git (sudah di .gitignore)
#
#  File ini (.env.example) AMAN untuk di-commit karena berisi
#  placeholder, bukan nilai asli.
# ═══════════════════════════════════════════════════════════════════

# ── Telegram ─────────────────────────────────────────────────────
# Dapatkan dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Chat ID tujuan notifikasi. Bisa personal atau group.
# Untuk group: -100xxxxxxxxxx (awali dengan -100)
# Cara cek: kirim pesan ke bot, lalu buka:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Bybit API ────────────────────────────────────────────────────
# HANYA diperlukan jika auto_trade=true di config.json
# Buat API key di: https://www.bybit.com/app/user/api-management
#
# Permission yang diperlukan:
#   - Derivatives: Read & Trade
#   - Unified Trading: Read & Trade
#
# KEAMANAN:
#   - Aktifkan IP whitelist jika VPS memiliki IP statis
#   - JANGAN aktifkan permission "Withdraw" atau "Transfer"
BYBIT_KEY=your_bybit_api_key_here
BYBIT_SECRET=your_bybit_api_secret_here
