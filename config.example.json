{
  "auto_trade": false,
  "debug": false,
  "env": "PROD",

  "api": {
    "bybit_key": "YOUR_BYBIT_API_KEY",
    "bybit_secret": "YOUR_BYBIT_API_SECRET",
    "telegram_bot_token": "YOUR_TELEGRAM_BOT_TOKEN",
    "telegram_chat_id": "YOUR_TELEGRAM_CHAT_ID"
  },

  "system": {
    "timezone": "Asia/Jakarta",
    "max_threads": 20,
    "check_interval_minutes": 15,
    "entry_timeframe": "15m",
    "trend_timeframe": "1h",
    "min_candles_analysis": 150,
    "watchlist_top_n": 100,
    "active_hours_utc": [6, 22]
  },

  "risk": {
    "use_max_leverage": true,
    "target_leverage": 25,
    "max_leverage_cap": 20,
    "risk_percent": 0.01,
    "max_positions": 3,
    "max_daily_loss_pct": 0.01,
    "daily_profit_target_pct": 0.015,
    "max_daily_trades": 3,
    "pending_expire_hours": 3,
    "tp_split": [0.4, 0.3, 0.3],
    "atr_sl_multiplier": 1.5,
    "atr_sl_length": 14,
    "paper_balance": 100.0
  },

  "setup": {
    "fib_entry_start": 0.5,
    "fib_entry_end": 0.618,
    "fib_sl": 0.27,
    "fib_tp_1": 1.0,
    "fib_tp_2": 1.618,
    "fib_tp_3": 2.618
  },

  "strategy": {
    "min_tech_score": 3,
    "min_quant_score": 3,
    "min_smc_score": 2,
    "min_deriv_score": 2,
    "max_entry_drift_pct": 0.03,
    "risk_reward_min": 2.5,
    "min_adx": 15,
    "min_tp1_distance_pct": 0.002,
    "min_atr_pct": 0.001,
    "max_atr_pct": 0.03,
    "require_sl_beyond_swing": false,
    "sl_swing_buffer_atr": 0
  },

  "indicators": {
    "min_rvol": 1.5
  },

  "patterns": {
    "tolerance": 0.015,
    "double_top": true,
    "double_bottom": true,
    "bull_flag": true,
    "bear_flag": true,
    "ascending_triangle": true,
    "descending_triangle": true,
    "bullish_rectangle": true
  },

  "pattern_signals": {
    "double_bottom": "Long",
    "double_top": "Short",
    "bull_flag": "Long",
    "bear_flag": "Short",
    "ascending_triangle": "Long",
    "descending_triangle": "Short",
    "bullish_rectangle": "Long"
  }
}
